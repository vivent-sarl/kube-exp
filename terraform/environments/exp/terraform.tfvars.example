region          = "eu-west-1"
env             = "exp"
cluster_name    = "hey_cluster"
cluster_version = "1.34"
vpc_id          = "VPC_ID HERE"
subnet_ids      = ["SUBNET-ID1 HERE","SUBNET-ID2 HERE"]

eks_addons_pre_node = {
  "kube-proxy" = {
    version = "v1.34.6-eksbuild.2"
  }
  "vpc-cni" = {
    version = "v1.20.5-eksbuild.1"
  }
}

eks_addons_post_node = {
  "coredns" = {
    version = "v1.12.4-eksbuild.10"
  }
  "metrics-server" = {
    version = "v0.8.1-eksbuild.10"
  }
  "amazon-cloudwatch-observability" = {
    version = "v6.2.0-eksbuild.1" # Check latest version
  }
  "eks-node-monitoring-agent" = {
    version = "v1.6.5-eksbuild.1" # Check latest version
  }
}

node_groups = {
  "system" = {
    instance_types = ["t3.medium"] # Smaller for system workloads
    desired_size   = 1
    max_size       = 1
    min_size       = 1
  }
  "workers" = {
    instance_types = ["t3.large"] # Larger for application workloads
    desired_size   = 1
    max_size       = 1
    min_size       = 1
  }
}

tags = {
  Environment = "exp"
  ManagedBy   = "terraform"
  Team        = "platform"
}
